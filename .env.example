# Frontend Environment Variables
# Copy this to .env.local for development

# Telegram Bot API URL
# For local development:
VITE_BOT_API_URL=http://localhost:3001

# For production (deploy your bot server):
# VITE_BOT_API_URL=https://your-bot-api.example.com

# Firebase (if using Firebase backend in future)
# VITE_FIREBASE_API_KEY=your_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_project_id
